local function toggle(label, key)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1,0,0,UserInputService.TouchEnabled and 44 or 36)
	button.BorderSizePixel = 0
	button.Font = Enum.Font.GothamSemibold
	button.TextSize = 12
	button.Parent = panel
	Instance.new("UICorner", button).CornerRadius = UDim.new(0,8)
	local function render()
		button.Text = label .. "   [" .. (state[key] and "ON" or "OFF") .. "]"
		button.BackgroundColor3 = state[key] and Color3.fromRGB(105,235,155) or Color3.fromRGB(40,44,52)
		button.TextColor3 = state[key] and Color3.fromRGB(12,20,15) or Color3.fromRGB(225,230,238)
	end
	renders[key] = render
	button.Activated:Connect(function()
		state[key] = not state[key]
		if key == "farmCoins" and state[key] then
			state.growExisting, state.growNew = false, false
			state.autoEat, state.autoDrink = true, true
			runtimeMessage = "Farm de moedas ativo"
		elseif (key == "growExisting" or key == "growNew") and state[key] then
			state.farmCoins = false
		end
		for _, changedKey in { key, "farmCoins", "growExisting", "growNew", "autoEat", "autoDrink" } do
			if renders[changedKey] then renders[changedKey]() end
		end
	end)
	render()
end
