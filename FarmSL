local function rebuildTeleportList()
	refreshCompletionSpawns()
	for _, child in spawnList:GetChildren() do
		if child:IsA("TextButton") or child:IsA("TextLabel") then child:Destroy() end
	end
	if #completionSpawnParts == 0 then
		local empty = Instance.new("TextLabel")
		empty.Size = UDim2.new(1,0,0,42)
		empty.BackgroundTransparency = 1
		empty.Font = Enum.Font.Gotham
		empty.TextColor3 = Color3.fromRGB(180,185,195)
		empty.TextSize = 12
		empty.Text = "Nenhum local encontrado em workspace.Spawns"
		empty.Parent = spawnList
		return
	end
	for _, part in completionSpawnParts do
		local destination = part
		local button = Instance.new("TextButton")
		button.Size = UDim2.new(1,0,0,UserInputService.TouchEnabled and 48 or 40)
		button.BackgroundColor3 = Color3.fromRGB(39,45,55)
		button.BorderSizePixel = 0
		button.Font = Enum.Font.GothamSemibold
		button.TextColor3 = Color3.fromRGB(232,238,247)
		button.TextSize = 11
		button.TextWrapped = true
		button.Text = completionSpawnLabel(destination)
		button.Parent = spawnList
		Instance.new("UICorner", button).CornerRadius = UDim.new(0,7)
		button.Activated:Connect(function()
			if not destination.Parent then
				runtimeMessage = "Esse local nao existe mais"
				rebuildTeleportList()
				return
			end
			selectedCompletionSpawn = destination
			runtimeMessage = "Teleportando para " .. completionSpawnLabel(destination)
			task.spawn(ragdollTeleport, destination.Position)
		end)
	end
end

